{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=AIGuardDb;Trusted_Connection=true;TrustServerCertificate=true;MultipleActiveResultSets=true;"
  },
  "JwtSettings": {
    "Issuer": "AIGuardControlTower",
    "Audience": "AIGuardClients",
    "ExpiryMinutes": 60,
    "RefreshExpiryDays": 7
  },
  "BootstrapPlatformAdmin": {
    "Email": "platform@aiguard.com",
    "Password": "PlatformPassword@123"
  },
  "ScanReceiptSettings": {
    "Secret": ""
  },
  "Authentication": {
    "MaxFailedLoginAttempts": 5,
    "LockoutMinutes": 15,
    "RateLimitPerMinute": 20
  },
  "MfaSettings": {
    "ChallengeExpiryMinutes": 5,
    "MaxAttempts": 5
  },
  "SsoProviders": {
    "Microsoft": {
      "Enabled": false,
      "Authority": "https://login.microsoftonline.com/common/v2.0",
      "ClientId": ""
    },
    "Google": {
      "Enabled": false,
      "Authority": "https://accounts.google.com",
      "ClientId": ""
    }
  },
  "PublicApp": {
    "BaseUrl": "http://localhost:5173"
  },
  "PublicApi": {
    "BaseUrl": "http://127.0.0.1:5185"
  },
  "Email": {
    "FromAddress": "no-reply@aiguard.local",
    "FromName": "AIGuard Control Tower",
    "SmtpHost": "",
    "SmtpPort": 587,
    "EnableSsl": true,
    "SmtpUsername": "",
    "SmtpPassword": ""
  },
  "BlockchainSettings": {
    "Enabled": false,
    "RpcUrl": "https://rpc-amoy.polygon.technology",
    "ChainId": 80002,
    "ContractAddress": "0x0000000000000000000000000000000000000000",
    "WalletAddress": "0x0000000000000000000000000000000000000000",
    "AnchorIntervalMinutes": 5,
    "MaxRetries": 8,
    "RetryBaseSeconds": 30,
    "BatchSize": 1000
  },
  "OcrSettings": {
    "Endpoint": "",
    "ApiKey": "",
    "ApiKeyHeader": "Ocp-Apim-Subscription-Key",
    "TimeoutSeconds": 30
  },
  "GovernanceWorkers": {
    "RetentionIntervalHours": 24,
    "IntegrationIntervalSeconds": 30
  },
  "CorsSettings": {
    "AllowedOrigins": [ "http://localhost:5173", "http://localhost:5174", "http://localhost:3000" ]
  },
  "BootstrapPlatformAdmin": {
    "Email": "platform@aiguard.com",
    "Password": "PlatformPassword@123"
  }
}
