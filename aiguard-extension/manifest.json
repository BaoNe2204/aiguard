{
  "manifest_version": 3,
  "name": "AIGuard Endpoint DLP",
  "version": "1.3.0",
  "description": "Ngăn dữ liệu nhạy cảm của doanh nghiệp bị gửi tới AI và phát hiện website AI chưa được phép.",
  "permissions": [
    "storage",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*",
    "https://copilot.microsoft.com/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://copilot.microsoft.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "storage": {
    "managed_schema": "managed_schema.json"
  },
  "action": {
    "default_title": "AIGuard Endpoint DLP",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "blocked.js", "ui.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
